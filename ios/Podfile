platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['EXCLUDED_ARCHS[sdk=iphoneos*]'] = 'x86_64'
    end
  end
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['EXCLUDED_ARCHS[sdk=iphoneos*]'] = 'x86_64'
  end

  # Add a Run Script phase to patch frameworks that have IOSSIMULATOR platform marker
  runner_project_path = File.expand_path('../Runner.xcodeproj', __FILE__)
  runner_project = Xcodeproj::Project.open(runner_project_path)
  runner_target = runner_project.targets.find { |t| t.name == 'Runner' }

  if runner_target
    runner_target.build_configurations.each do |config|
      config.build_settings['EXCLUDED_ARCHS[sdk=iphoneos*]'] = 'x86_64'
    end
    runner_project.save

    phase_name = 'Strip Simulator Platform Slices'
    existing = runner_target.build_phases.find { |p| p.respond_to?(:name) && p.name == phase_name }

    existing.remove_from_project if existing
    if true
      phase = runner_target.new_shell_script_build_phase(phase_name)
      phase.shell_script = <<~'SHELL'
        #!/bin/bash
        set -e
        # Only patch for device builds — simulator builds need IOSSIMULATOR platform markers
        if [[ "$PLATFORM_NAME" == *"simulator"* ]]; then
          echo "Simulator build — skipping platform patch"
          exit 0
        fi
        APP="${TARGET_BUILD_DIR}/${WRAPPER_NAME}"
        SDK=$(xcrun --sdk iphoneos --show-sdk-version)
        find "$APP" -name '*.framework' -type d | while read -r FW; do
          EXEC=$(defaults read "$FW/Info.plist" CFBundleExecutable 2>/dev/null || true)
          [ -z "$EXEC" ] && continue
          BIN="$FW/$EXEC"
          [ -f "$BIN" ] || continue
          # Strip x86_64 (simulator-only arch) from device builds
          if lipo -archs "$BIN" 2>/dev/null | grep -q "x86_64"; then
            echo "Stripping x86_64 from $EXEC"
            lipo -remove x86_64 "$BIN" -output "${BIN}.stripped" && mv "${BIN}.stripped" "$BIN"
          fi
          # Patch IOSSIMULATOR platform markers to IOS for device builds
          if vtool -show-build "$BIN" 2>/dev/null | grep -q "IOSSIMULATOR"; then
            MIN_OS=$(defaults read "$FW/Info.plist" MinimumOSVersion 2>/dev/null || echo "${IPHONEOS_DEPLOYMENT_TARGET:-15.0}")
            echo "Patching $EXEC: IOSSIMULATOR -> IOS (minos=$MIN_OS)"
            vtool -set-build-version ios "$MIN_OS" "$SDK" -replace -output "${BIN}.fixed" "$BIN"
            mv "${BIN}.fixed" "$BIN"
          fi
        done
      SHELL
      runner_project.save
      puts "Added '#{phase_name}' build phase to Runner target"
    end
  end
end
